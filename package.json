{
  "name": "ibuild",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm:dev\" \"npm:server\"",
    "server": "node --watch server/index.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "vitest run --config vitest.server.config.js",
    "test:e2e": "playwright test",
    "db:migrate": "prisma migrate dev --schema server/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema server/db/prisma/schema.prisma",
    "db:seed": "node server/db/seed.js",
    "db:studio": "prisma studio --schema server/db/prisma/schema.prisma"
  },
  "prisma": {
    "schema": "server/db/prisma/schema.prisma",
    "seed": "node server/db/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^0.575.0",
    "multer": "^2.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "nock": "^14.0.0",
    "prisma": "^6.6.0",
    "supertest": "^7.1.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
